<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="28"
      alignment="TOP_CENTER"
      styleClass="dashboard-container"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.travelplanner.ManageSharedTripController"
      stylesheets="@style.css">

    <padding>
        <Insets top="35"
                 right="35"
                 bottom="35"
                 left="35"/>
    </padding>

    <!-- LEFT COLUMN -->

    <VBox spacing="24"
          HBox.hgrow="ALWAYS"
          style="
              -fx-background-color: white;
              -fx-background-radius: 24;
              -fx-padding: 28;
              -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.10), 18, 0.2, 0, 8);
          ">

        <!-- HEADER -->

        <VBox spacing="6">

            <Label fx:id="tripTitleLabel"
                   text="Manage Shared Trip"
                   styleClass="dashboard-title"/>

            <Label text="Share this itinerary with friends and manage collaboration permissions."
                   styleClass="dashboard-subtitle"
                   wrapText="true"/>

        </VBox>

        <!-- SHARE FORM -->

        <VBox spacing="14">

            <TextField fx:id="uidField"
                       promptText="Enter Friend UID"
                       maxWidth="Infinity"
                       styleClass="login-input"/>

            <ComboBox fx:id="permissionBox"
                      promptText="Select Permission"
                      maxWidth="Infinity"
                      styleClass="form-combo-box"/>

            <Button text="Share Trip"
                    prefWidth="170"
                    styleClass="button-primary"
                    onAction="#shareTrip"/>

        </VBox>

        <!-- BACK -->

        <Button text="Back"
                prefWidth="120"
                styleClass="button-secondary"
                onAction="#goBack"/>

    </VBox>

    <!-- RIGHT COLUMN -->

    <VBox spacing="22"
          HBox.hgrow="ALWAYS"
          style="
              -fx-background-color: white;
              -fx-background-radius: 24;
              -fx-padding: 28;
              -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.10), 18, 0.2, 0, 8);
          ">

        <!-- CURRENT SHARES -->

        <VBox spacing="6">

            <Label text="Currently Shared With"
                   styleClass="dashboard-title"/>

            <Label text="Users who currently have access to this trip."
                   styleClass="dashboard-subtitle"/>

        </VBox>

        <!-- SHARED USERS LIST -->

        <ListView fx:id="sharedUsersListView"
                  VBox.vgrow="ALWAYS"
                  styleClass="itinerary-list"/>

        <!-- ACTIONS -->

        <HBox spacing="14">

            <Button text="Toggle Permission"
                    prefWidth="190"
                    styleClass="button-secondary"
                    onAction="#togglePermission"/>

            <Button text="Remove Access"
                    prefWidth="170"
                    styleClass="button-danger"
                    onAction="#removeAccess"/>

        </HBox>

    </VBox>

    <HBox.hgrow>
        <Priority fx:constant="ALWAYS"/>
    </HBox.hgrow>

</HBox>