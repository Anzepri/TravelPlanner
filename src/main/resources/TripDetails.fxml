<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="22"
      styleClass="details-page"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.travelplanner.TripDetailsController"
      stylesheets="@style.css">

    <padding>
        <Insets top="30" right="34" bottom="30" left="34"/>
    </padding>

    <VBox spacing="8" styleClass="details-header">
        <Label fx:id="tripTitle" styleClass="details-title"/>
        <HBox spacing="14">

        <Label fx:id="destinationLabel"
           styleClass="details-meta-pill"/>

        <Label fx:id="startDateLabel"
           styleClass="details-meta-pill"/>

        <Label fx:id="endDateLabel"
           styleClass="details-meta-pill"/>

        <Label fx:id="permissionLabel"
           styleClass="details-meta-pill"/>

        </HBox>
    </VBox>

    <VBox spacing="14" styleClass="itinerary-editor">
        <Label text="Itinerary" styleClass="section-title"/>

        <HBox spacing="12" alignment="CENTER_LEFT">
            <DatePicker fx:id="datePicker"
                        promptText="Date"
                        HBox.hgrow="ALWAYS"
                        maxWidth="Infinity"
                        styleClass="form-date-picker"/>

            <TextField fx:id="activityField"
                       promptText="Activity"
                       HBox.hgrow="ALWAYS"
                       maxWidth="Infinity"
                       styleClass="login-input"/>

            <HBox spacing="6" alignment="CENTER" styleClass="time-picker-group">
                <ComboBox fx:id="hourBox" prefWidth="74" styleClass="form-combo-box"/>
                <Label text=":" styleClass="time-separator"/>
                <ComboBox fx:id="minuteBox" prefWidth="74" styleClass="form-combo-box"/>
                <ComboBox fx:id="ampmBox" prefWidth="82" styleClass="form-combo-box"/>
            </HBox>

            <TextField fx:id="locationField"
                       promptText="Location"
                       HBox.hgrow="ALWAYS"
                       maxWidth="Infinity"
                       styleClass="login-input"/>
        </HBox>

    <HBox spacing="10">
        <Button fx:id="addButton"
            text="Add"
            prefWidth="110"
            styleClass="button-primary"
            onAction="#addActivity"/>
        <Button fx:id="editButton"
            text="Edit"
            prefWidth="110"
            styleClass="button-secondary"
            onAction="#editActivity"/>
        <Button fx:id="deleteButton"
            text="Delete"
            prefWidth="110"
            styleClass="button-danger"
            onAction="#deleteActivity"/>
    </HBox>
    </VBox>

    <ListView fx:id="itineraryListView"
              styleClass="itinerary-list"
              VBox.vgrow="ALWAYS"/>

    <Button text="Back"
            prefWidth="110"
            styleClass="button-secondary"
            onAction="#goBack"/>

</VBox>