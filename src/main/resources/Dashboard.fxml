<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_LEFT"
      styleClass="dashboard-container"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.travelplanner.DashboardController"
      stylesheets="@style.css">

    <padding>
        <Insets top="28"
                 right="28"
                 bottom="28"
                 left="28"/>
    </padding>

    <!-- HEADER -->

    <VBox spacing="6">

        <Label text="Travel Planner Dashboard"
               styleClass="dashboard-title"/>

        <Label text="Your trips, ready when you are."
               styleClass="dashboard-subtitle"/>

    </VBox>

    <!-- TRIP GRID -->

    <ScrollPane fitToWidth="true"
                VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER"
                styleClass="dashboard-scroll">

        <FlowPane fx:id="tripFlowPane"
                  styleClass="trip-grid"/>

    </ScrollPane>

    <!-- ACTION BUTTONS -->

    <HBox spacing="12"
           alignment="CENTER_LEFT">

        <Button text="Back"
                prefWidth="150"
                styleClass="button-secondary"
                onAction="#handleBack"/>

        <Button text="Create Trip"
                prefWidth="150"
                styleClass="button-primary"
                onAction="#goToCreateTrip"/>

        <Button text="Delete Trip"
                prefWidth="150"
                styleClass="button-danger"
                onAction="#handleDeleteTrip"/>


        <Button text="Shared Trips"
                prefWidth="150"
                styleClass="button-secondary"
                onAction="#goToSharedTrips"/>

        <Button text="Manage Sharing"
                prefWidth="150"
                styleClass="button-secondary"
                onAction="#manageSharing"/>

        <Button fx:id="manageUsersButton"
                text="Manage Users"
                prefWidth="150"
                styleClass="button-secondary"
                onAction="#goToUserManagement"/>
        


    </HBox>

</VBox>